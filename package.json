{
  "name": "wg-to-ws",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "WG_MODE=server bun run --watch src/server.ts",
    "dev:client": "WG_MODE=client bun run --watch src/client.ts",
    "dev": "bun run --watch src/index.ts",
    "check": "bun run tsc --noEmit",
    "build": "bun build --compile --outfile=wg-to-ws src/index.ts",
    "build:server": "bun build --compile --outfile=wg-to-ws-server src/server.ts",
    "build:client": "bun build --compile --outfile=wg-to-ws-client src/client.ts",
    "build:linux": "bun build --compile --target=bun-linux-x64 --outfile=wg-to-ws-linux-x64 src/index.ts",
    "build:server:linux": "bun build --compile --target=bun-linux-x64 --outfile=wg-to-ws-server-linux-x64 src/server.ts",
    "build:client:linux": "bun build --compile --target=bun-linux-x64 --outfile=wg-to-ws-client-linux-x64 src/client.ts",
    "build:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile=wg-to-ws-darwin-arm64 src/index.ts",
    "build:server:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile=wg-to-ws-server-darwin-arm64 src/server.ts",
    "build:client:darwin-arm64": "bun build --compile --target=bun-darwin-arm64 --outfile=wg-to-ws-client-darwin-arm64 src/client.ts",
    "build:windows-x64": "bun build --compile --target=bun-windows-x64 --outfile=wg-to-ws-windows-x64.exe src/index.ts",
    "build:server:windows-x64": "bun build --compile --target=bun-windows-x64 --outfile=wg-to-ws-server-windows-x64.exe src/server.ts",
    "build:client:windows-x64": "bun build --compile --target=bun-windows-x64 --outfile=wg-to-ws-client-windows-x64.exe src/client.ts",
    "build:all": "bun run build:linux && bun run build:darwin-arm64 && bun run build:windows-x64",
    "start": "bun run src/index.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "latest"
  }
}
